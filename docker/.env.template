# GopherPaw Desktop Container 环境配置
# 复制此文件为 .env 并修改配置

# ============================================
# Docker 镜像代理配置
# ============================================
# 使用镜像加速器（中国大陆推荐）
DOCKER_REGISTRY_MIRROR=docker.1ms.run

# ============================================
# VNC 远程桌面配置
# ============================================
# VNC 密码（请修改为强密码）
VNC_PASSWORD=gopherpaw

# 桌面分辨率
VNC_GEOMETRY=1920x1080

# 色深（24位真彩色）
VNC_DEPTH=24

# noVNC Web 端口（浏览器访问）
NOVNC_PORT=6080

# VNC 原生端口（VNC 客户端访问，默认禁用）
# VNC_PORT=5901

# ============================================
# GopherPaw 配置
# ============================================
# LLM API 密钥（必填）
GOPHERPAW_LLM_API_KEY=sk-your-api-key-here

# LLM API 端点（可选）
GOPHERPAW_LLM_BASE_URL=https://api.openai.com/v1

# 日志级别（debug/info/warn/error）
GOPHERPAW_LOG_LEVEL=info

# GopherPaw HTTP API 端口（TODO）
# GOPHERPAW_PORT=8081

# ============================================
# 系统配置
# ============================================
# 时区
TZ=Asia/Shanghai

# ============================================
# 高级配置（通常不需要修改）
# ============================================
# 容器名称
# CONTAINER_NAME=gopherpaw-desktop

# 镜像标签
# IMAGE_TAG=latest

# ============================================
# 安全提示
# ============================================
# ⚠️  重要：
# 1. VNC_PASSWORD 请使用强密码（至少 12 位，包含大小写字母、数字、特殊字符）
# 2. GOPHERPAW_LLM_API_KEY 请勿提交到 Git 仓库
# 3. 生产环境建议启用 HTTPS（使用反向代理如 Nginx）
# 4. 定期更换密码（建议每 90 天）

# ============================================
# 快速测试配置（仅用于开发环境）
# ============================================
# 如果只是本地测试，可以使用以下配置：
# VNC_PASSWORD=test123
# GOPHERPAW_LLM_API_KEY=sk-test-key
# VNC_GEOMETRY=1280x720
